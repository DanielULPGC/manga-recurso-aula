{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",

  "name": "Las eras de Japón y el manga — Biblioteca ULPGC",
  "short_name": "Manga ULPGC",
  "description": "Línea del tiempo interactiva, catálogo pedagógico de 280 títulos, situaciones de aprendizaje LOMLOE e itinerarios didácticos para Educación Infantil, Primaria, Secundaria y Bachillerato. Biblioteca del Campus del Obelisco · Aula de Cómic · ULPGC.",

  "start_url": "./",
  "scope": "./",

  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],

  "orientation": "any",

  "lang": "es-ES",
  "dir": "ltr",

  "background_color": "#0e0a04",
  "theme_color": "#0e0a04",

  "categories": ["education", "books", "reference"],

  "icons": [
    { "src": "./icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "./icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "./icons/icon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "./icons/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "./icons/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" }
  ],

  "shortcuts": [
    {
      "name": "Catálogo de títulos",
      "short_name": "Catálogo",
      "description": "Accede al catálogo completo de títulos del fondo",
      "url": "./recurso.html#catalogo",
      "icons": [{ "src": "./icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Situaciones de aprendizaje",
      "short_name": "SA LOMLOE",
      "description": "Situaciones de aprendizaje con estructura LOMLOE",
      "url": "./recurso.html#situaciones",
      "icons": [{ "src": "./icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Tabla currículo → manga",
      "short_name": "Currículo",
      "description": "Correspondencias entre contenidos curriculares y títulos del fondo",
      "url": "./recurso.html#curriculo",
      "icons": [{ "src": "./icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],

  "related_applications": [],
  "prefer_related_applications": false
}
